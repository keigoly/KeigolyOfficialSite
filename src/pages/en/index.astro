---
// src/pages/en/index.astro - KEIGOLY Official Site Top Page (English)
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/sections/Hero";
import SectionTitle from "../../components/ui/SectionTitle";
---

<BaseLayout title="TOP" lang="en" fullWidth={true}>
    <!-- Hero Section -->
    <Hero client:load />

    <!-- Works Section -->
    <section class="py-24 md:py-32 px-6 max-w-7xl mx-auto bg-kg-bg-alt">
        <SectionTitle client:visible title="WORKS" subtitle="What I Do" />

        <div class="text-center py-12">
            <p class="font-serif text-kg-text-muted mb-8 max-w-lg mx-auto">
                Working as a System Engineer at Palo Alto Networks while
                developing Chrome extensions.
            </p>
            <a
                href="/en/works"
                class="inline-flex items-center gap-2 font-display text-sm tracking-[0.2em] text-kg-text-muted hover:text-kg-accent transition-colors duration-300"
            >
                VIEW DETAILS
                <span class="text-lg">→</span>
            </a>
        </div>
    </section>

    <!-- Apps Section -->
    <section class="py-24 md:py-32 px-6 max-w-7xl mx-auto">
        <SectionTitle client:visible title="APPS" subtitle="Chrome Extensions" />

        <div class="text-center py-12">
            <p class="font-serif text-kg-text-muted mb-8 max-w-lg mx-auto">
                I develop and publish Chrome extensions aimed at improving user productivity
                and enhancing the browsing experience.
            </p>
            <a
                href="/en/apps"
                class="inline-flex items-center gap-2 font-display text-sm tracking-[0.2em] text-kg-text-muted hover:text-kg-accent transition-colors duration-300"
            >
                VIEW ALL APPS
                <span class="text-lg">&rarr;</span>
            </a>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-24 md:py-32 px-6 text-center">
        <h2
            class="font-display text-3xl md:text-4xl tracking-[0.3em] text-kg-text mb-6"
        >
            GET IN TOUCH
        </h2>
        <p class="text-kg-text-muted font-serif mb-8 max-w-md mx-auto">
            Feel free to reach out for project consultations or inquiries
        </p>
        <a
            href="/en/contact"
            class="inline-block px-10 py-4 border border-kg-accent text-kg-accent font-display text-sm tracking-[0.2em] hover:bg-kg-accent hover:text-kg-bg transition-all duration-300"
        >
            CONTACT
        </a>
    </section>
</BaseLayout>
